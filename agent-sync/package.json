{
  "name": "agentsync",
  "displayName": "AgentSync",
  "description": "Multiplayer AI agent code synchronization & conflict resolution tool.",
  "publisher": "ArfDAO",
  "version": "0.0.1",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "collaboration",
    "agent",
    "sync",
    "multiplayer"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "authentication": [
      {
        "id": "github",
        "label": "GitHub"
      }
    ],
    "configuration": {
      "title": "AgentSync",
      "properties": {
        "agentsync.yjsServerUrl": {
          "type": "string",
          "default": "ws://localhost:1234",
          "description": "Yjs senkronizasyon sunucusu (port 1234)"
        },
        "agentsync.ctrlServerUrl": {
          "type": "string",
          "default": "ws://localhost:1235",
          "description": "Akıllı Trafik Ajanı kontrol kanalı (port 1235)"
        }
      }
    },
    "commands": [
      {
        "command": "agentsync.forceUnlock",
        "title": "AgentSync: Force Unlock All Files"
      },
      {
        "command": "agentsync.setWalletKey",
        "title": "AgentSync: Set Monad Wallet Private Key"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "ws": "^8.20.1",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.0.0"
  }
}
